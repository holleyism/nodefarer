# Nodefarer backend config. Copy to .env (gitignored) on the GPU box and fill in.
# Real environment variables override these. Never commit the real .env.

# Neo4j — same contract as the Python ingest. On the box this is localhost.
NEO4J_URI=bolt://localhost:7689
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Vector index created by ingest/load_embeddings.py
VECTOR_INDEX=work_embedding

# HTTP
PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
RATE_RPS=120

# Optional static bearer gate (leave empty to disable on the LAN).
# Firebase token validation replaces this later.
AUTH_TOKEN=

# Optional external Atlas JSON to serve at /api/v1/atlas. Leave empty to use the
# atlas compiled into the binary (backend/cmd/api/atlas.json).
ATLAS_PATH=
