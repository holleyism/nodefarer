# Copy to ingest/.env (gitignored) and fill in. Never commit real values;
# each host keeps its own .env.
#
# Host AND port live in the URI. Examples:
#   bolt://localhost:7687          local default
#   bolt://gpubox.lan:7688         another host + a non-default published port
#   neo4j://gpubox.lan:7688        routing (cluster); single instance use bolt://
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
